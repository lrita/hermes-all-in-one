#!/command/with-contenv sh
# shellcheck shell=sh
#
# 修正 hermes-webui 相关目录的归属，确保 s6-rc 中以 hermes 身份启动
# 的 hermes-webui / hermes-webui-log 服务能正常读写。
#
# 背景：基础镜像 hermes-agent 的 stage2-hook（/etc/cont-init.d/01-hermes-setup）
# 已经在容器启动时把 /opt/data 顶层及一组已知子目录（cron / sessions /
# logs / workspace / ...）chown 给 hermes，并在 venv owner 与运行期
# hermes UID 不一致时递归 chown /opt/hermes 下的 .venv / gateway /
# ui-tui / node_modules。但它有两个覆盖盲区：
#
#   * 只对【已存在】的子目录 chown（`[ -e $HERMES_HOME/$sub ]` 守卫）。
#     首次挂载空 volume 时 workspace / webui 还不存在，会被直接跳过。
#   * 子目录白名单是相对 /opt/data 的固定 basename，不识别本镜像引入
#     的环境变量覆盖路径（HERMES_WEBUI_*）。
#
# 因此本钩子在 stage2-hook 完成 UID 重映射之后再补齐三条 WebUI 路径：
#
#   * HERMES_WEBUI_DIR                (默认 /opt/hermes-webui)  ── 构建期 git clone
#                                                                   产出的源码与缓存
#   * HERMES_WEBUI_STATE_DIR          (默认 /opt/data/webui)    ── 运行期写入的
#                                                                   sessions / 日志
#   * HERMES_WEBUI_DEFAULT_WORKSPACE  (默认 /opt/data/workspace) ── WebUI 默认
#                                                                   workspace 落盘位置
#
# 处理策略：
#   - 顶层 mkdir -p 保证目录存在，避免服务首启时以 hermes 身份 mkdir
#     撞 EACCES（state/workspace 路径常因 volume 首挂而不存在）
#   - chown -R hermes:hermes（这三棵子树由 hermes 独占管理，不存在
#     host bind-mount 误改外部文件的风险）
#   - 失败时仅告警不 fail，与 stage2-hook 在 rootless 场景的处理一致
#
# 命名按字典序排在 03-rtk-init 之后；这样 stage2 → supervise-perms →
# reconcile-profiles → rtk-init → webui-setup 顺序依次完成所有运行期
# 准备工作，最后才 fork s6-rc 启动各 service。

set -eu

: "${HERMES_WEBUI_DIR:=/opt/hermes-webui}"
: "${HERMES_WEBUI_STATE_DIR:=/opt/data/webui}"
: "${HERMES_WEBUI_DEFAULT_WORKSPACE:=/opt/data/workspace}"

# 非 root 启动的容器（例如 rootless podman / 显式 --user）已无 CAP_CHOWN，
# 直接跳过：宿主侧应自行保证目录归属正确。与 stage2-hook 的处理一致。
if [ "$(id -u)" != 0 ]; then
    echo "[04-webui-setup] not root — skipping chown"
    exit 0
fi

# state / workspace 在镜像内不一定存在：可能由 volume 首次挂载产生空目录，
# 也可能完全没创建。先 mkdir -p 再 chown，避免 webui 服务首启时
# 以 hermes 身份去 mkdir 子目录撞 EACCES。
# HERMES_WEBUI_DIR 由构建期 git clone 创建，这里不再 mkdir。
mkdir -p "$HERMES_WEBUI_STATE_DIR" "$HERMES_WEBUI_DEFAULT_WORKSPACE"

for dir in \
    "$HERMES_WEBUI_DIR" \
    "$HERMES_WEBUI_STATE_DIR" \
    "$HERMES_WEBUI_DEFAULT_WORKSPACE" \
; do
    [ -e "$dir" ] || continue
    chown -R hermes:hermes "$dir" 2>/dev/null || \
        echo "[04-webui-setup] Warning: chown $dir failed (rootless container?) — continuing"
done
